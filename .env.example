# Copy to .env and fill in your keys. Never commit the real .env.

# --- LLM provider API keys ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
PERPLEXITY_API_KEY=

# --- Database ---
# Postgres is the primary/production database. The default below matches the
# docker-compose stack; for a bare-metal install point it at your own server.
DATABASE_URL=postgresql+psycopg://lumora:lumora@localhost:5432/lumora
# SQLite fallback for quick local dev / CLI usage (no Postgres required).
# If DATABASE_URL is unset entirely, the app falls back to SQLite automatically.
# DATABASE_URL=sqlite:///./lumora.db

# --- App ---
ENVIRONMENT=development
DEBUG=true

# --- Scheduler ---
SCHEDULER_ENABLED=true
SCHEDULER_TIMEZONE=UTC

# --- Default models ---
DEFAULT_PROVIDER_MODEL=gpt-4o-mini
DEFAULT_JUDGE_MODEL=claude-haiku-4-5-20251001
# Max output tokens per provider request. Reasoning models (e.g.
# gemini-2.5-flash) burn ~1.5k hidden "thinking" tokens before the visible
# answer, so keep this high enough to avoid truncating responses.
DEFAULT_MAX_TOKENS=4096

# --- Snapshot capture ---
# Models queried on every snapshot (one per provider, comma-separated).
# Providers without an API key above are skipped automatically.
# NOTE: gemini-2.0-flash was retired by Google (404); use gemini-2.5-flash.
SNAPSHOT_MODELS=gpt-4o-mini,claude-haiku-4-5-20251001,gemini-2.5-flash
# Variance passes per prompt per provider (AI answers are non-deterministic).
RUNS_PER_PROMPT=3

# --- Alerting ---
# After each snapshot, the new mention rate is compared with the previous run;
# an alert fires when it moves by at least ALERT_THRESHOLD (a fraction, so
# 0.10 = 10 percentage points). Increases and decreases both alert.
ALERT_THRESHOLD=0.10
# Public dashboard URL. When set, alerts include a deep link to the project.
BASE_URL=

# All three channels are optional — leave a channel's vars blank to disable it.

# Slack: an incoming-webhook URL (https://hooks.slack.com/services/...).
SLACK_WEBHOOK_URL=

# Email (SMTP). Needs at minimum SMTP_HOST + ALERT_EMAIL_FROM + ALERT_EMAIL_TO.
# SMTP_USER/SMTP_PASSWORD are optional for relays that don't require auth.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=

# Telegram: a bot token (from @BotFather) and the target chat id.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
