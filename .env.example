# Copy to .env and fill in your keys. Never commit the real .env.

# --- LLM provider API keys ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
PERPLEXITY_API_KEY=

# --- Database ---
# Postgres is the primary/production database. The default below matches the
# docker-compose stack; for a bare-metal install point it at your own server.
DATABASE_URL=postgresql+psycopg://lumora:lumora@localhost:5432/lumora
# SQLite fallback for quick local dev / CLI usage (no Postgres required).
# If DATABASE_URL is unset entirely, the app falls back to SQLite automatically.
# DATABASE_URL=sqlite:///./lumora.db

# --- App ---
ENVIRONMENT=development
DEBUG=true

# --- Scheduler ---
SCHEDULER_ENABLED=true
SCHEDULER_TIMEZONE=UTC

# --- Default models ---
DEFAULT_PROVIDER_MODEL=gpt-4o-mini
DEFAULT_JUDGE_MODEL=claude-haiku-4-5-20251001

# --- Snapshot capture ---
# Models queried on every snapshot (one per provider, comma-separated).
# Providers without an API key above are skipped automatically.
SNAPSHOT_MODELS=gpt-4o-mini,claude-haiku-4-5-20251001,gemini-2.0-flash
# Variance passes per prompt per provider (AI answers are non-deterministic).
RUNS_PER_PROMPT=3
