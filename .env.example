# Copy to .env and fill in your keys. Never commit the real .env.

# --- LLM provider API keys ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
PERPLEXITY_API_KEY=

# --- Database ---
# SQLite (MVP default):
DATABASE_URL=sqlite:///./lumora.db
# Postgres (production), e.g.:
# DATABASE_URL=postgresql+psycopg://lumora:lumora@localhost:5432/lumora

# --- App ---
ENVIRONMENT=development
DEBUG=true

# --- Scheduler ---
SCHEDULER_ENABLED=true
SCHEDULER_TIMEZONE=UTC

# --- Default models ---
DEFAULT_PROVIDER_MODEL=gpt-4o
DEFAULT_JUDGE_MODEL=claude-sonnet-4-6
